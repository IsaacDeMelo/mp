<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Inscrições</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 1100px; margin: 24px auto; padding: 0 16px; }
    .top { display: flex; justify-content: space-between; align-items: center; }
    .card { border: 1px solid #ddd; border-radius: 10px; padding: 16px; margin-bottom: 16px; }
    input, button { padding: 10px; margin: 6px 0; box-sizing: border-box; }
    .error { background: #ffe5e5; color: #8f1111; padding: 10px; border-radius: 8px; margin-bottom: 12px; }
    table { width: 100%; border-collapse: collapse; }
    th, td { border-bottom: 1px solid #eee; padding: 8px; text-align: left; font-size: 13px; }
    .mono { font-family: Consolas, monospace; font-size: 12px; }
  </style>
</head>
<body>
  <div class="top">
    <h1>Painel administrativo</h1>
    <form action="/admin/<%= adminPath %>/logout" method="POST">
      <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
      <button type="submit">Sair</button>
    </form>
  </div>

  <% if (error) { %>
    <div class="error"><%= error %></div>
  <% } %>

  <section class="card">
    <h2>Criar cupom de caravana</h2>
    <form action="/admin/<%= adminPath %>/coupons" method="POST">
      <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
      <div>
        <label>Código (string única)</label><br />
        <input type="text" name="code" placeholder="caravana_rionovo" required />
      </div>
      <div>
        <label>Desconto em R$</label><br />
        <input type="number" name="discountAmount" min="0.01" step="0.01" required />
      </div>
      <button type="submit">Criar cupom</button>
    </form>
  </section>

  <section class="card">
    <h2>Cupons</h2>
    <table>
      <thead>
        <tr>
          <th>Código</th>
          <th>Desconto</th>
          <th>Status</th>
          <th>Usado em</th>
        </tr>
      </thead>
      <tbody>
        <% coupons.forEach(function(c) { %>
          <tr>
            <td><%= c.code %></td>
            <td>R$ <%= Number(c.discountAmount).toFixed(2) %></td>
            <td><%= c.isUsed ? 'utilizado' : 'disponível' %></td>
            <td class="mono"><%= c.usedByPaymentId || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>

  <section class="card">
    <h2>Todas as inscrições</h2>
    <table>
      <thead>
        <tr>
          <th>Data</th>
          <th>Nome</th>
          <th>E-mail</th>
          <th>Telefone</th>
          <th>Qtd sem almoço</th>
          <th>Qtd com almoço</th>
          <th>Subtotal</th>
          <th>Desconto</th>
          <th>Total</th>
          <th>Status</th>
          <th>Cupom</th>
        </tr>
      </thead>
      <tbody>
        <% transactions.forEach(function(t) { %>
          <tr>
            <td><%= t.createdAt %></td>
            <td><%= t.buyerName %></td>
            <td><%= t.buyerEmail %></td>
            <td><%= t.buyerPhone || '-' %></td>
            <td><%= t.quantityWithoutLunch %></td>
            <td><%= t.quantityWithLunch %></td>
            <td>R$ <%= Number(t.subtotalAmount || 0).toFixed(2) %></td>
            <td>R$ <%= Number(t.discountAmount || 0).toFixed(2) %></td>
            <td>R$ <%= Number(t.amount).toFixed(2) %></td>
            <td><%= t.status %></td>
            <td><%= t.couponCode || '-' %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </section>
</body>
</html>
