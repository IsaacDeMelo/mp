<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Login</title>
  <style>
    :root {
      --bg: #f5f5f7;
      --panel: rgba(255,255,255,0.92);
      --line: #e6e6eb;
      --text: #1d1d1f;
      --muted: #6e6e73;
      --accent: #0071e3;
      --error-bg: rgba(127, 29, 29, 0.35);
      --error-text: #fecaca;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px;
      font-family: "SF Pro Text", "SF Pro Display", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top, #ffffff 0%, #eceff7 45%, #dde6f8 100%);
    }
    .shell { width: 100%; max-width: 520px; }
    .card {
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 26px;
      backdrop-filter: blur(18px);
      background: var(--panel);
      box-shadow: 0 24px 55px rgba(15, 23, 42, 0.13);
    }
    h1 { margin: 0 0 8px; font-size: clamp(1.5rem, 3.4vw, 2rem); letter-spacing: -0.02em; }
    p { margin: 0 0 18px; color: var(--muted); font-size: 15px; }
    label { font-size: 14px; font-weight: 600; color: var(--muted); }
    input, button {
      width: 100%;
      padding: 13px 14px;
      margin: 8px 0;
      box-sizing: border-box;
      border-radius: 12px;
      border: 1px solid var(--line);
      font-size: 15px;
    }
    input { background: #fff; color: var(--text); }
    button {
      border: 0;
      background: linear-gradient(135deg, #0ea5e9, #0071e3);
      color: #fff;
      font-weight: 700;
      cursor: pointer;
      margin-top: 14px;
    }
    .error { background: var(--error-bg); color: var(--error-text); padding: 10px; border-radius: 10px; margin-bottom: 12px; }
  </style>
</head>
<body>
  <main class="shell">
    <section class="card">
      <h1>Painel administrativo</h1>
      <p>Acesso privado para cupons, inscrições e acompanhamento financeiro.</p>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form action="/admin/<%= adminPath %>/login" method="POST" autocomplete="off">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
        <label>Senha administrativa</label>
        <input type="password" name="password" required />
        <button type="submit">Entrar no painel</button>
      </form>
    </section>
  </main>
</body>
</html>
