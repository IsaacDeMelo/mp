<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Login</title>
  <style>
    :root {
      --bg: #0f172a;
      --panel: rgba(255,255,255,0.08);
      --line: rgba(255,255,255,0.16);
      --text: #f8fafc;
      --muted: #cbd5e1;
      --accent: #38bdf8;
      --error-bg: rgba(127, 29, 29, 0.35);
      --error-text: #fecaca;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 24px;
      font-family: Inter, Arial, sans-serif;
      color: var(--text);
      background: radial-gradient(circle at top, #1e293b, #0f172a 60%);
    }
    .shell { width: 100%; max-width: 520px; }
    .card {
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 24px;
      backdrop-filter: blur(14px);
      background: var(--panel);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.35);
    }
    h1 { margin: 0 0 8px; }
    p { margin: 0 0 18px; color: var(--muted); }
    input, button {
      width: 100%;
      padding: 12px 14px;
      margin: 8px 0;
      box-sizing: border-box;
      border-radius: 12px;
      border: 1px solid var(--line);
      font-size: 15px;
    }
    input { background: rgba(255,255,255,0.04); color: var(--text); }
    button {
      border: 0;
      background: linear-gradient(135deg, #38bdf8, #2563eb);
      color: #fff;
      font-weight: 700;
      cursor: pointer;
      margin-top: 14px;
    }
    .error { background: var(--error-bg); color: var(--error-text); padding: 10px; border-radius: 10px; margin-bottom: 12px; }
  </style>
</head>
<body>
  <main class="shell">
    <section class="card">
      <h1>Painel administrativo</h1>
      <p>Acesso privado para cupons, inscrições e acompanhamento financeiro.</p>
      <% if (error) { %>
        <div class="error"><%= error %></div>
      <% } %>
      <form action="/admin/<%= adminPath %>/login" method="POST" autocomplete="off">
        <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
        <label>Senha administrativa</label>
        <input type="password" name="password" required />
        <button type="submit">Entrar no painel</button>
      </form>
    </section>
  </main>
</body>
</html>
