<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin - Login</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 560px; margin: 24px auto; padding: 0 16px; }
    .card { border: 1px solid #ddd; border-radius: 10px; padding: 16px; }
    input, button { width: 100%; padding: 10px; margin: 6px 0; box-sizing: border-box; }
    .error { background: #ffe5e5; color: #8f1111; padding: 10px; border-radius: 8px; margin-bottom: 12px; }
  </style>
</head>
<body>
  <h1>Painel administrativo</h1>
  <% if (error) { %>
    <div class="error"><%= error %></div>
  <% } %>
  <section class="card">
    <form action="/admin/<%= adminPath %>/login" method="POST" autocomplete="off">
      <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
      <label>Senha administrativa</label>
      <input type="password" name="password" required />
      <button type="submit">Entrar</button>
    </form>
  </section>
</body>
</html>
