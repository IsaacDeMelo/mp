<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inscrição e pagamento PIX</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hachi+Maru+Pop&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #f6f7fb;
            --card: #ffffff;
            --text: #222;
            --muted: #6b7280;
            --line: #e5e7eb;
            --primary: #2563eb;
            --danger-bg: #ffe5e5;
            --danger-text: #8f1111;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Inter, Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        .container {
            max-width: 1000px;
            margin: 28px auto;
            padding: 0 16px;
        }

        .title {
            margin: 0 0 6px;
        }

        .subtitle {
            margin: 0 0 18px;
            color: var(--muted);
        }

        .layout {
            display: grid;
            grid-template-columns: 1.3fr 0.9fr;
            gap: 18px;
            align-items: start;
        }

        .card {
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 18px;
        }

        .error {
            background: var(--danger-bg);
            color: var(--danger-text);
            border-radius: 10px;
            padding: 10px;
            margin-bottom: 12px;
        }

        h2 {
            margin-top: 0;
            font-size: 18px;
        }

        label {
            display: block;
            margin: 10px 0 4px;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--line);
            border-radius: 10px;
        }

        .grid2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .muted {
            color: var(--muted);
            font-size: 13px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            font-size: 14px;
        }

        .summary-total {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px dashed var(--line);
            font-weight: 700;
            font-size: 17px;
            display: flex;
            justify-content: space-between;
        }

        .payment-options {
            display: grid;
            gap: 10px;
            margin-top: 14px;
        }

        .payment-option {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px;
            display: flex;
            gap: 10px;
            align-items: flex-start;
            background: #fafafa;
        }

        .payment-option input {
            width: auto;
            margin-top: 4px;
        }

        .card-block {
            margin-top: 14px;
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px;
            display: none;
        }

        .card-block.active {
            display: block;
        }

        .card-block input,
        .card-block select {
            margin-top: 6px;
        }

        /* Containers dos iframes seguros do Mercado Pago */
        #form-checkout__cardNumber,
        #form-checkout__expirationDate,
        #form-checkout__securityCode {
            border: 1px solid var(--line);
            border-radius: 10px;
            margin-top: 6px;
            background: #fff;
        }

        .card-row2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .alert {
            background: #fff7ed;
            color: #9a3412;
            padding: 10px;
            border-radius: 10px;
            margin: 10px 0;
            display: none;
        }

        button {
            width: 100%;
            margin-top: 14px;
            border: 0;
            border-radius: 10px;
            padding: 12px;
            background: var(--primary);
            color: #fff;
            font-weight: 600;
            cursor: pointer;
        }

        @media (max-width: 840px) {
            .layout {
                grid-template-columns: 1fr;
            }
        }

        .event-image-wrap {
            width: 100%;
            background: linear-gradient(135deg, #49ffdd 0%, #2563eb 60%, #80e0f7 100%);
            display: flex;
            justify-content: center;
        }

        .event-image {
            display: flex;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            width: 100%;
            height: auto;
            max-width: 1600px;
            margin-bottom: 120px; 
        }
    </style>
</head>

<body>
    <div class="event-image-wrap">
        <img class="event-image" src="/2026 (3).png" alt="Banner 2026" />
    </div>
    <main class="container" data-base-price="<%= Number(prices.base).toFixed(2) %>"
        data-lunch-price="<%= Number(prices.lunch).toFixed(2) %>">
        <h1 class="title">Inscrição</h1>
        <p class="subtitle">Escolha as quantidades como em um carrinho e gere o PIX em um clique.</p>

        <% if (error) { %>
            <div class="error">
                <%= error %>
            </div>
            <% } %>

                <form id="checkout-form" action="/checkout" method="POST" autocomplete="off" class="layout">
                    <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />

                    <section class="card">
                        <h2>Dados do responsável</h2>
                        <label>Nome completo</label>
                        <input type="text" name="buyerName" required maxlength="120" />

                        <label>E-mail</label>
                        <input type="email" name="buyerEmail" required />

                        <label>Telefone (opcional)</label>
                        <input type="tel" name="buyerPhone" maxlength="30" />

                        <h2 style="margin-top:16px;">Seu carrinho</h2>
                        <div class="grid2">
                            <div>
                                <label>Ingressos sem almoço</label>
                                <input id="qtyWithout" type="number" name="quantityWithoutLunch" min="0" step="1"
                                    value="1" required />
                                <div class="muted">R$ <%= Number(prices.base).toFixed(2) %> por ingresso</div>
                            </div>
                            <div>
                                <label>Ingressos com almoço</label>
                                <input id="qtyWith" type="number" name="quantityWithLunch" min="0" step="1" value="0"
                                    required />
                                <div class="muted">R$ <%= Number(prices.base + prices.lunch).toFixed(2) %> por ingresso
                                </div>
                            </div>
                        </div>

                        <div style="margin-top:10px;">
                            <label>Cupom de desconto (opcional)</label>
                            <input type="text" id="couponInput" placeholder="ex: caravana_rionovo ou lider_rionovo" />
                            <input type="hidden" name="caravanCouponCode" id="caravanCouponCode" />
                            <input type="hidden" name="leaderCouponCode" id="leaderCouponCode" />
                        </div>
                        <div class="muted">Apenas 1 cupom por compra (caravana ou líder).</div>
                    </section>

                    <aside class="card">
                        <h2>Resumo do pedido</h2>
                        <div class="summary-row"><span>Sem almoço</span><strong id="lineWithout">R$ 1.00</strong></div>
                        <div class="summary-row"><span>Com almoço</span><strong id="lineWith">R$ 0.00</strong></div>
                        <div class="summary-total"><span>Total estimado</span><span id="total">R$ 1.00</span></div>
                        <p class="muted">O desconto é calculado ao finalizar. Cupom de líder vale só para 1 ingresso da
                            compra.</p>

                        <input type="hidden" name="paymentMethod" value="pix" />
                        <p class="muted">Pagamento disponível no momento: PIX.</p>

                        <button type="submit">Gerar PIX</button>
                    </aside>
                </form>
    </main>

    <script>
        (function () {
            const container = document.querySelector('.container');
            const base = Number(container?.dataset.basePrice || '0');
            const lunch = Number(container?.dataset.lunchPrice || '0');
            const qtyWithout = document.getElementById('qtyWithout');
            const qtyWith = document.getElementById('qtyWith');
            const lineWithout = document.getElementById('lineWithout');
            const lineWith = document.getElementById('lineWith');
            const total = document.getElementById('total');
            const couponInput = document.getElementById('couponInput');
            const caravanCouponCodeInput = document.getElementById('caravanCouponCode');
            const leaderCouponCodeInput = document.getElementById('leaderCouponCode');

            // Conjunto de prefixos que identificam cupons de líder (case-insensitive)
            const LEADER_PREFIXES = ['lider', 'líder'];

            function routeCoupon(value) {
                const code = value.trim().toLowerCase();
                const isLeader = LEADER_PREFIXES.some((p) => code.startsWith(p));
                if (isLeader) {
                    leaderCouponCodeInput.value = code;
                    caravanCouponCodeInput.value = '';
                } else if (code) {
                    caravanCouponCodeInput.value = code;
                    leaderCouponCodeInput.value = '';
                } else {
                    caravanCouponCodeInput.value = '';
                    leaderCouponCodeInput.value = '';
                }
            }

            if (couponInput) {
                couponInput.addEventListener('input', () => routeCoupon(couponInput.value));
            }

            function safeInt(v) {
                const n = Number(v);
                return Number.isInteger(n) && n > 0 ? n : 0;
            }

            function render() {
                const qWithout = safeInt(qtyWithout.value);
                const qWith = safeInt(qtyWith.value);
                const valueWithout = qWithout * base;
                const valueWith = qWith * (base + lunch);
                const grandTotal = valueWithout + valueWith;

                lineWithout.textContent = `R$ ${valueWithout.toFixed(2)}`;
                lineWith.textContent = `R$ ${valueWith.toFixed(2)}`;
                total.textContent = `R$ ${grandTotal.toFixed(2)}`;
            }

            qtyWithout.addEventListener('input', render);
            qtyWith.addEventListener('input', render);

            // Garante que o cupom seja roteado mesmo quando o form é submetido sem ter disparado 'input'
            document.getElementById('checkout-form').addEventListener('submit', () => {
                if (couponInput) routeCoupon(couponInput.value);
            });

            render();
        })();
    </script>
</body>

</html>