<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inscrição - Seminário Crianças para o Reino</title>
    <script>
        document.documentElement.classList.add('page-loading');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Hachi+Maru+Pop&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #f6f7fb;
            --card: #ffffff;
            --text: #222;
            --muted: #6b7280;
            --line: #e5e7eb;
            --primary: #2563eb;
            --danger-bg: #ffe5e5;
            --danger-text: #8f1111;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Inter, Arial, sans-serif;
            font-size: 18px;
            line-height: 1.5;
            background: var(--bg);
            color: var(--text);
            overflow-x: hidden;
        }

        #page-loader {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            background: #f6f7fb;
            color: #1f2937;
            font-size: 20px;
            z-index: 9999;
        }

        .loader-logo {
            width: min(180px, 42vw);
            height: auto;
            animation: loaderPulse 1.8s ease-in-out infinite;
            transform-origin: center;
            margin-bottom: 10px;
        }

        .loader-label {
            font-size: 18px;
            color: #374151;
        }

        @keyframes loaderPulse {
            0% {
                transform: scale(0.92);
                opacity: 0.82;
            }

            50% {
                transform: scale(1.04);
                opacity: 1;
            }

            100% {
                transform: scale(0.92);
                opacity: 0.82;
            }
        }

        .page-loading body > *:not(#page-loader) {
            visibility: hidden;
        }

        .page-loading #page-loader {
            display: flex;
        }

        .container {
            max-width: 1000px;
            margin: 28px auto;
            padding: 0 16px;
        }

        .title {
            margin: 0 0 6px;
            text-align: center;
            margin: 40px;
        }

        .subtitle {
            margin: 0 0 18px;
            color: var(--muted);
        }

        .layout {
            display: grid;
            grid-template-columns: 1.3fr 0.9fr;
            gap: 18px;
            align-items: start;
        }

        .card {
            background: var(--card);
            border: 1px solid var(--line);
            border-radius: 14px;
            padding: 18px;
        }

        .error {
            background: var(--danger-bg);
            color: var(--danger-text);
            border-radius: 10px;
            padding: 10px;
            margin-bottom: 12px;
        }

        .session-payment {
            background: linear-gradient(165deg, #f5f9ff 0%, #eef6ff 100%);
            border: 1px solid #cfe0ff;
            border-radius: 14px;
            padding: 14px;
            margin-bottom: 14px;
            box-shadow: 0 8px 20px rgba(37, 99, 235, 0.08);
        }

        .session-payment.hidden {
            display: none;
        }

        .session-payment-title {
            margin: 0 0 8px;
            font-size: 20px;
            font-weight: 700;
        }

        .session-payment-row {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .session-payment-small {
            font-size: 15px;
            color: var(--muted);
            margin: 6px 0 0;
        }

        .session-payment-status {
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            border-radius: 999px;
            padding: 3px 10px;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }

        .status-pending {
            color: #854d0e;
            background: #fef3c7;
        }

        .status-approved,
        .status-authorized {
            color: #166534;
            background: #dcfce7;
        }

        .status-rejected,
        .status-cancelled,
        .status-expired {
            color: #991b1b;
            background: #fee2e2;
        }

        .status-updated {
            color: #334155;
            background: #e2e8f0;
        }

        .status-cancelled,
        .status-rejected,
        .status-expired {
            color: #8f1111;
        }

        .session-payment-link,
        .session-payment-btn {
            border: 0;
            border-radius: 8px;
            padding: 8px 10px;
            font-size: 16px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .session-payment-link {
            background: #2563eb;
            color: #fff;
        }

        .session-payment-btn {
            background: #e5e7eb;
            color: #111827;
        }

        h2 {
            margin-top: 0;
            font-size: 24px;
        }

        label {
            display: block;
            margin: 10px 0 4px;
            font-size: 18px;
        }

        input {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--line);
            border-radius: 10px;
            font-size: 18px;
        }

        .grid2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .product-list {
            display: flex;
            gap: 12px;
            margin-top: 30px;
            margin-bottom: 30px;
            width: 100%;
            flex-wrap: wrap;
        }

        .product-card {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px;
            background: #fafafa;
            flex: 1 1 calc((100% - 12px) / 2);
            min-width: 0;
            max-width: calc((100% - 12px) / 2);
        }

        .product-photo {
            width: 100%;
            aspect-ratio: 4 / 3;
            border: 1px dashed #bfc6d4;
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
            position: relative;
            margin-bottom: 10px;
        }

        .product-photo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            object-position: center;
            display: block;
            background: #fff;
        }

        .product-photo-placeholder {
            position: absolute;
            inset: 0;
            color: var(--muted);
            display: none;
            align-items: center;
            justify-content: center;
            text-align: center;
            font-size: 15px;
            padding: 8px;
            background: #fff;
        }

        .product-name {
            font-weight: 600;
            margin-bottom: 2px;
        }

        .product-price {
            color: var(--muted);
            font-size: 16px;
            margin-bottom: 10px;
        }

        .qty-control {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .qty-btn {
            width: 34px;
            height: 34px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            background: #fff;
            color: #0f172a;
            font-weight: 700;
            font-size: 22px;
            line-height: 1;
            padding: 0;
            margin: 0;
            cursor: pointer;
            flex: 0 0 34px;
        }

        .qty-input {
            width: 72px;
            text-align: center;
            margin: 0;
        }

        .muted {
            color: var(--muted);
            font-size: 16px;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            font-size: 18px;
        }

        .summary-total {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 1px dashed var(--line);
            font-weight: 700;
            font-size: 22px;
            display: flex;
            justify-content: space-between;
        }

        .payment-options {
            display: grid;
            gap: 10px;
            margin-top: 14px;
        }

        .payment-option {
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px;
            display: flex;
            gap: 10px;
            align-items: flex-start;
            background: #fafafa;
        }

        .payment-option input {
            width: auto;
            margin-top: 4px;
        }

        .card-block {
            margin-top: 14px;
            border: 1px solid var(--line);
            border-radius: 12px;
            padding: 12px;
            display: none;
        }

        .card-block.active {
            display: block;
        }

        .card-block input,
        .card-block select {
            margin-top: 6px;
        }

        /* Containers dos iframes seguros do Mercado Pago */
        #form-checkout__cardNumber,
        #form-checkout__expirationDate,
        #form-checkout__securityCode {
            border: 1px solid var(--line);
            border-radius: 10px;
            margin-top: 6px;
            background: #fff;
        }

        .card-row2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }

        .alert {
            background: #fff7ed;
            color: #9a3412;
            padding: 10px;
            border-radius: 10px;
            margin: 10px 0;
            display: none;
        }

        .checkout-submit {
            width: 100%;
            margin-top: 14px;
            border: 0;
            border-radius: 10px;
            padding: 12px;
            background: var(--primary);
            color: #fff;
            font-weight: 600;
            cursor: pointer;
        }

        @media (max-width: 840px) {
            .layout {
                grid-template-columns: 1fr;
            }

            .container {
                padding: 0 12px;
            }

            .card {
                padding: 12px;
            }

            .product-list {
                gap: 8px;
            }

            .product-card {
                flex-basis: calc((100% - 8px) / 2);
                max-width: calc((100% - 8px) / 2);
                padding: 8px;
            }

            .qty-control {
                gap: 4px;
                display: flex;
                justify-content: center;
            }

            .qty-btn {
                width: 30px;
                height: 30px;
                flex-basis: 30px;
                font-size: 18px;
            }

            .qty-input {
                width: 52px;
                padding: 6px 4px;
                font-size: 16px;
            }
        }

        @media (min-width: 841px) {
            .event-image {
                width: 30%;
            }
        }

        .event-image-wrap {
            width: 100%;
            background: linear-gradient(135deg, #49ffdd 0%, #2563eb 60%, #80e0f7 100%);
            display: flex;
            justify-content: center;
        }

        .event-image {
            display: block;
            width: auto;
            height: auto;
            max-width: 100%;
            margin-bottom: 30px; 
        }
        form {
            padding: 0px;
        }
        .card{
            padding: 20px;
        }
    </style>
</head>

<body>
    <div id="page-loader">
        <img class="loader-logo" src="/logoad.png" alt="Carregando" />
    </div>
    <div class="event-image-wrap">
        <img class="event-image" src="/2026.png" alt="Banner 2026" />
    </div>
    <main class="container" data-base-price="<%= Number(prices.base).toFixed(2) %>"
        data-lunch-price="<%= Number(prices.lunch).toFixed(2) %>">
        <section id="session-payment" class="session-payment hidden" aria-live="polite">
            <p class="session-payment-title">Pagamento salvo nesta sessão</p>
            <div class="session-payment-row">
                <span>Status:</span>
                <strong id="session-payment-status" class="session-payment-status"></strong>
                <a id="session-payment-link" class="session-payment-link" href="#">Abrir pagamento</a>
                <button id="session-payment-refresh" class="session-payment-btn" type="button">Atualizar status</button>
                <button id="session-payment-close" class="session-payment-btn" type="button">Fechar pendência</button>
            </div>
            <p id="session-payment-meta" class="session-payment-small"></p>
        </section>



        <% if (error) { %>
            <div class="error">
                <%= error %>
            </div>
            <% } %>

                <form id="checkout-form" action="/checkout" method="POST" autocomplete="off" class="layout">
                    <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />

                    <section class="card">
                        <h2>Dados do responsável</h2>
                        <label>Nome completo</label>
                        <input type="text" name="buyerName" required maxlength="120" />

                        <label>E-mail</label>
                        <input type="email" name="buyerEmail" required />

                        <label>Telefone (opcional)</label>
                        <input type="tel" name="buyerPhone" maxlength="30" />
                        <div class="product-list">
                            <article class="product-card">
                                <div class="product-photo">
                                    <img class="product-photo-img" src="/3.png" alt="Foto do inscrição sem almoço" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <span class="product-photo-placeholder">Adicione a foto em /public/produto-sem-almoco.png</span>
                                </div>
                                <div class="product-name">Iscrição sem almoço</div>
                                <div class="product-price">R$ <%= Number(prices.base).toFixed(2) %> por inscrição</div>
                                <div class="qty-control">
                                    <button type="button" class="qty-btn" data-target="qtyWithout" data-step="-1" aria-label="Diminuir inscrição sem almoço">-</button>
                                    <input class="qty-input" id="qtyWithout" type="number" name="quantityWithoutLunch" min="0" step="1" value="1" required />
                                    <button type="button" class="qty-btn" data-target="qtyWithout" data-step="1" aria-label="Aumentar inscrição sem almoço">+</button>
                                </div>
                            </article>

                            <article class="product-card">
                                <div class="product-photo">
                                    <img class="product-photo-img" src="/4.png" alt="Foto do inscrição com almoço" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <span class="product-photo-placeholder">Adicione a foto em /public/produto-com-almoco.png</span>
                                </div>
                                <div class="product-name">Inscrição com almoço</div>
                                <div class="product-price">R$ <%= Number(prices.base + prices.lunch).toFixed(2) %> por inscrição</div>
                                <div class="qty-control">
                                    <button type="button" class="qty-btn" data-target="qtyWith" data-step="-1" aria-label="Diminuir inscrição com almoço">-</button>
                                    <input class="qty-input" id="qtyWith" type="number" name="quantityWithLunch" min="0" step="1" value="0" required />
                                    <button type="button" class="qty-btn" data-target="qtyWith" data-step="1" aria-label="Aumentar inscrição com almoço">+</button>
                                </div>
                            </article>
                        </div>

                        <div style="margin-top:10px;">
                            <label>Cupom de desconto (opcional)</label>
                            <div style="display: flex; gap: 8px;">
                                <input type="text" id="couponInput" placeholder="Código do cupom" style="flex: 1;" />
                                <button type="button" id="applyCouponBtn" class="btn" style="padding: 10px 16px; width: auto; font-size: 14px; min-height: 48px;">Aplicar</button>
                            </div>
                            <small id="couponMessage" style="display:block; margin-top:5px; color:#4a4a4a; font-weight: bold;"></small>
                            <input type="hidden" name="caravanCouponCode" id="caravanCouponCode" />
                            <input type="hidden" name="leaderCouponCode" id="leaderCouponCode" />
                        </div>
                  
                    </section>

                    <aside class="card">
                        <h2>Resumo do pedido</h2>
                        <div class="summary-row"><span>Sem almoço</span><strong id="lineWithout">R$ 1.00</strong></div>
                        <div class="summary-row"><span>Com almoço</span><strong id="lineWith">R$ 0.00</strong></div>
                        <div class="summary-total"><span>Total estimado</span><span id="total">R$ 1.00</span></div>
                        <p class="muted">O desconto é calculado ao finalizar. Cupom de líder vale só para 1 inscrição da
                            compra.</p>

                        <input type="hidden" name="paymentMethod" value="pix" />
                        <p class="muted">Pagamento disponível no momento: PIX.</p>

                        <button class="checkout-submit" type="submit">Gerar PIX</button>
                    </aside>
                </form>
    </main>

    <script>
        (function () {
            function unlockPage() {
                document.documentElement.classList.remove('page-loading');
            }

            if (document.readyState === 'complete') {
                unlockPage();
                return;
            }

            window.addEventListener('load', unlockPage, { once: true });
        })();

        (function () {
            const container = document.querySelector('.container');
            const base = Number(container?.dataset.basePrice || '0');
            const lunch = Number(container?.dataset.lunchPrice || '0');
            const qtyWithout = document.getElementById('qtyWithout');
            const qtyWith = document.getElementById('qtyWith');
            const lineWithout = document.getElementById('lineWithout');
            const lineWith = document.getElementById('lineWith');
            const total = document.getElementById('total');
            const couponInput = document.getElementById('couponInput');
            const caravanCouponCodeInput = document.getElementById('caravanCouponCode');
            const leaderCouponCodeInput = document.getElementById('leaderCouponCode');
            const pendingBox = document.getElementById('session-payment');
            const pendingStatusEl = document.getElementById('session-payment-status');
            const pendingMetaEl = document.getElementById('session-payment-meta');
            const pendingLinkEl = document.getElementById('session-payment-link');
            const pendingRefreshEl = document.getElementById('session-payment-refresh');
            const pendingCloseEl = document.getElementById('session-payment-close');
            const storageKey = 'mp:lastPayment';

            // Conjunto de prefixos que identificam cupons de líder (case-insensitive)
            const LEADER_PREFIXES = ['lider', 'líder'];

            function routeCoupon(value) {
                const code = value.trim().toLowerCase();
                const isLeader = LEADER_PREFIXES.some((p) => code.startsWith(p));
                if (isLeader) {
                    leaderCouponCodeInput.value = code;
                    caravanCouponCodeInput.value = '';
                } else if (code) {
                    caravanCouponCodeInput.value = code;
                    leaderCouponCodeInput.value = '';
                } else {
                    caravanCouponCodeInput.value = '';
                    leaderCouponCodeInput.value = '';
                }
            }

            if (couponInput) {
                couponInput.addEventListener('input', () => {
                    routeCoupon(couponInput.value);
                    const msgEl = document.getElementById('couponMessage');
                    if(msgEl && !couponInput.value.trim()) msgEl.textContent = '';
                });
            }

            function safeInt(v) {
                const n = Number(v);
                return Number.isInteger(n) && n > 0 ? n : 0;
            }

            function formatarDataBrasilia(data) {
                if (!data) return 'agora';
                try {
                    return new Intl.DateTimeFormat('pt-BR', {
                        timeZone: 'America/Sao_Paulo',
                        dateStyle: 'short',
                        timeStyle: 'medium'
                    }).format(new Date(data));
                } catch (e) {
                    return 'agora';
                }
            }

            function statusLabel(status) {
                if (status === 'approved' || status === 'authorized') return 'Aprovado';
                if (status === 'pending') return 'Aguardando';
                if (status === 'rejected') return 'Recusado';
                if (status === 'cancelled') return 'Cancelado';
                if (status === 'expired') return 'Expirado';
                return 'Atualizado';
            }

            function readSessionPayment() {
                try {
                    const raw = localStorage.getItem(storageKey);
                    if (!raw) return null;
                    const parsed = JSON.parse(raw);
                    if (!parsed || !parsed.localPaymentId) return null;
                    return parsed;
                } catch (e) {
                    return null;
                }
            }

            function saveSessionPayment(data) {
                localStorage.setItem(storageKey, JSON.stringify(data));
            }

            function clearSessionPayment() {
                localStorage.removeItem(storageKey);
                if (pendingBox) pendingBox.classList.add('hidden');
            }

            function paintSessionPayment(state) {
                if (!pendingBox || !state) return;

                const status = String(state.status || 'pending');
                pendingBox.classList.remove('hidden');

                if (pendingStatusEl) {
                    pendingStatusEl.textContent = statusLabel(status);
                    pendingStatusEl.className = `session-payment-status status-${status || 'updated'}`;
                }

                if (pendingMetaEl) {
                    const updated = formatarDataBrasilia(state.updatedAt);
                    pendingMetaEl.textContent = `Pagamento: ${state.localPaymentId} • Atualizado em: ${updated}`;
                }

                if (pendingLinkEl) {
                    pendingLinkEl.href = `/payment/${state.localPaymentId}`;
                }
            }

            async function refreshSessionPaymentStatus() {
                const state = readSessionPayment();
                if (!state || !state.localPaymentId) {
                    clearSessionPayment();
                    return;
                }

                try {
                    const response = await fetch(`/payments/${state.localPaymentId}/status`, {
                        headers: { Accept: 'application/json' }
                    });

                    if (!response.ok) {
                        paintSessionPayment(state);
                        return;
                    }

                    const latest = await response.json();
                    const next = {
                        ...state,
                        status: latest.status,
                        statusDetail: latest.statusDetail || null,
                        updatedAt: latest.updatedAt,
                        url: `/payment/${state.localPaymentId}`
                    };

                    saveSessionPayment(next);
                    paintSessionPayment(next);
                } catch (e) {
                    paintSessionPayment(state);
                }
            }

            let debounceTimer;
            async function apiRender() {
                const qWithout = safeInt(qtyWithout.value);
                const qWith = safeInt(qtyWith.value);
                const coupon = couponInput ? couponInput.value.trim() : '';

                try {
                    const response = await fetch(`/api/calculate-price?quantityWithoutLunch=${qWithout}&quantityWithLunch=${qWith}&couponCode=${encodeURIComponent(coupon)}`);
                    if (response.ok) {
                        const data = await response.json();
                        if (data.success) {
                            const valueWithout = qWithout * base;
                            const valueWith = qWith * (base + lunch);
                            
                            lineWithout.textContent = `R$ ${valueWithout.toFixed(2)}`;
                            lineWith.textContent = `R$ ${valueWith.toFixed(2)}`;
                            
                            if (data.amounts) {
                                total.textContent = `R$ ${data.amounts.total.toFixed(2)}`;
                                
                                const msgEl = document.getElementById('couponMessage');
                                if (msgEl) {
                                    if (data.couponStatus === 'valid') {
                                        let discount = data.amounts.discountAmount;
                                        if (discount > 0) {
                                            msgEl.style.color = 'green';
                                            msgEl.textContent = `Cupom aplicado! Desconto de R$ ${discount.toFixed(2)}`;
                                        } else {
                                            msgEl.style.color = '#4a4a4a';
                                            msgEl.textContent = 'Cupom válido, mas sem desconto aplicável.';
                                        }
                                    } else if (data.couponStatus === 'invalid') {
                                        msgEl.style.color = 'red';
                                        msgEl.textContent = 'Cupom inválido ou expirado.';
                                    } else {
                                        msgEl.textContent = '';
                                    }
                                }
                            }
                        }
                    }
                } catch (e) {
                    console.error('Erro ao calcular subtotal', e);
                }
            }

            function render() {
                const qWithout = safeInt(qtyWithout.value);
                const qWith = safeInt(qtyWith.value);
                const valueWithout = qWithout * base;
                const valueWith = qWith * (base + lunch);
                const grandTotal = valueWithout + valueWith;

                lineWithout.textContent = `R$ ${valueWithout.toFixed(2)}`;
                lineWith.textContent = `R$ ${valueWith.toFixed(2)}`;
                total.textContent = `R$ ${grandTotal.toFixed(2)}`;
                
                clearTimeout(debounceTimer);
                debounceTimer = setTimeout(apiRender, 300);
            }

            if (couponInput) {
                const applyBtn = document.getElementById('applyCouponBtn');
                if (applyBtn) {
                    applyBtn.addEventListener('click', () => {
                        apiRender();
                    });
                }
            }

            qtyWithout.addEventListener('input', render);
            qtyWith.addEventListener('input', render);

            document.querySelectorAll('.qty-btn').forEach((btn) => {
                btn.addEventListener('click', () => {
                    const targetId = btn.dataset.target;
                    const delta = Number(btn.dataset.step || '0');
                    const input = document.getElementById(targetId);
                    if (!input) return;

                    const current = Number(input.value);
                    const safeCurrent = Number.isInteger(current) && current > 0 ? current : 0;
                    const next = Math.max(0, safeCurrent + delta);

                    input.value = String(next);
                    render();
                });
            });

            // Garante que o cupom seja roteado mesmo quando o form é submetido sem ter disparado 'input'
            document.getElementById('checkout-form').addEventListener('submit', () => {
                if (couponInput) routeCoupon(couponInput.value);
            });

            if (pendingRefreshEl) {
                pendingRefreshEl.addEventListener('click', refreshSessionPaymentStatus);
            }

            if (pendingCloseEl) {
                pendingCloseEl.addEventListener('click', clearSessionPayment);
            }

            const existing = readSessionPayment();
            if (existing) {
                paintSessionPayment(existing);
                refreshSessionPaymentStatus();
            }

            render();
        })();
    </script>
</body>

</html>