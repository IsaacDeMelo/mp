<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inscrição e pagamento PIX</title>
    <style>
        body { font-family: Arial, sans-serif; max-width: 760px; margin: 24px auto; padding: 0 16px; }
        .card { border: 1px solid #ddd; border-radius: 10px; padding: 16px; }
        input, button { width: 100%; padding: 10px; margin: 6px 0; box-sizing: border-box; }
        button { cursor: pointer; }
        .error { background: #ffe5e5; color: #8f1111; padding: 10px; border-radius: 8px; margin-bottom: 12px; }
        .small { font-size: 13px; color: #555; }
        .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    </style>
</head>
<body>
    <h1>Inscrição sem login</h1>
    <p class="small">Ingresso: R$ <%= Number(prices.base).toFixed(2) %> | Almoço adicional por ingresso: R$ <%= Number(prices.lunch).toFixed(2) %></p>

    <% if (error) { %>
        <div class="error"><%= error %></div>
    <% } %>

    <section class="card">
        <form action="/checkout" method="POST" autocomplete="off">
            <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />

            <label>Nome completo</label>
            <input type="text" name="buyerName" required maxlength="120" />

            <label>E-mail</label>
            <input type="email" name="buyerEmail" required />

            <label>Telefone (opcional)</label>
            <input type="tel" name="buyerPhone" maxlength="30" />

            <div class="grid2">
                <div>
                    <label>Qtd. ingressos sem almoço</label>
                    <input type="number" name="quantityWithoutLunch" min="0" step="1" value="1" required />
                </div>
                <div>
                    <label>Qtd. ingressos com almoço</label>
                    <input type="number" name="quantityWithLunch" min="0" step="1" value="0" required />
                </div>
            </div>

            <label>Cupom (opcional)</label>
            <input type="text" name="couponCode" placeholder="ex: caravana_rionovo" />

            <button type="submit">Gerar PIX</button>
        </form>
    </section>
</body>
</html>