<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pagamento PIX</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 760px; margin: 24px auto; padding: 0 16px; }
    .card { border: 1px solid #ddd; border-radius: 10px; padding: 16px; }
    .mono { font-family: Consolas, monospace; font-size: 12px; word-break: break-all; }
    .small { font-size: 12px; color: #555; }
    .status-pending { color: #856404; }
    .status-approved { color: #155724; font-weight: 700; }
    .status-rejected, .status-cancelled { color: #721c24; font-weight: 700; }
  </style>
</head>
<body>
  <h1>Pagamento da inscrição</h1>

  <section class="card">
    <p><strong>Participante:</strong> <%= currentPayment.buyerName %></p>
    <p><strong>E-mail:</strong> <%= currentPayment.buyerEmail %></p>
    <p><strong>Qtd sem almoço:</strong> <%= currentPayment.quantityWithoutLunch %></p>
    <p><strong>Qtd com almoço:</strong> <%= currentPayment.quantityWithLunch %></p>
    <p><strong>Subtotal:</strong> R$ <%= Number(currentPayment.subtotalAmount).toFixed(2) %></p>
    <p><strong>Desconto:</strong> R$ <%= Number(currentPayment.discountAmount || 0).toFixed(2) %> <% if (currentPayment.couponCode) { %>(cupom: <%= currentPayment.couponCode %>)<% } %></p>
    <p><strong>Total:</strong> R$ <%= Number(currentPayment.amount).toFixed(2) %></p>
    <p>
      Status:
      <strong id="payment-status" class="status-<%= currentPayment.status %>"><%= currentPayment.status %></strong>
      <% if (currentPayment.statusDetail) { %>
        <span class="small">(<%= currentPayment.statusDetail %>)</span>
      <% } %>
    </p>

    <% if (currentPayment.qrCodeBase64) { %>
      <img alt="QR Code PIX" width="240" src="data:image/png;base64,<%= currentPayment.qrCodeBase64 %>" />
    <% } %>

    <% if (currentPayment.qrCode) { %>
      <p class="small">Copia e cola PIX:</p>
      <p class="mono"><%= currentPayment.qrCode %></p>
    <% } %>

    <p class="small">Última atualização: <span id="updated-at"><%= currentPayment.updatedAt %></span></p>
  </section>

  <script>
    (function () {
      const paymentId = "<%= currentPayment.localPaymentId %>";
      let active = true;

      async function pollStatus() {
        if (!active) return;
        try {
          const response = await fetch(`/payments/${paymentId}/status`, { headers: { Accept: 'application/json' } });
          if (!response.ok) return;
          const data = await response.json();
          const statusEl = document.getElementById('payment-status');
          const updatedAtEl = document.getElementById('updated-at');

          if (statusEl) {
            statusEl.textContent = data.status;
            statusEl.className = `status-${data.status}`;
          }
          if (updatedAtEl) {
            updatedAtEl.textContent = data.updatedAt;
          }

          if (data.status !== 'pending') {
            active = false;
          }
        } catch (e) {
          // ignora falha momentânea
        }
      }

      if ("<%= currentPayment.status %>" === 'pending') {
        setInterval(pollStatus, 5000);
      }
    })();
  </script>
</body>
</html>
