PORT=3000
NODE_ENV=development
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/mercadopago?retryWrites=true&w=majority

# Token de teste do Mercado Pago
MERCADO_PAGO_PUBLIC_KEY=TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MERCADO_PAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL pública da sua aplicação (necessária para webhook)
# Em desenvolvimento local use um túnel (ex.: ngrok) e coloque a URL https pública aqui
BASE_URL=https://SEU-ENDERECO-PUBLICO

# Segredo forte para sessão e webhook
SESSION_SECRET=troque-por-um-segredo-forte-e-longo
MERCADO_PAGO_WEBHOOK_TOKEN=troque-por-um-token-secreto-webhook
ADMIN_PASSWORD=troque-por-uma-senha-admin-forte
